# Telegram Bot
ANIMA_TELEGRAM_TOKEN=your_bot_token_here
ANIMA_TELEGRAM_CHAT_ID=your_chat_id_here

# LLM (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_API_KEY_INPUT=optional_separate_key_for_input_llm

# Optional: override LLM models/URL
# ANIMA_LLM_URL=https://openrouter.ai/api/v1/chat/completions
